<style is:global>
  .reveal {
    opacity: 0;
    transform: translateY(40px);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // .reveal クラスを持つ要素にスクロールアニメーションを適用
  document.querySelectorAll('.reveal').forEach((el) => {
    gsap.to(el, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        once: true,
      },
    });
  });
</script>