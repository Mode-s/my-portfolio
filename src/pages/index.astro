---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="container">
      <p class="hero-tag">Web Developer</p>
      <h1 class="hero-title">Hello, I'm Shota.</h1>
      <p class="hero-sub">フロントエンド技術を学びながら、ものづくりを楽しんでいます。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: calc(100vh - 64px);
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    margin-bottom: 16px;
    letter-spacing: 2px;
  }

  .hero-title {
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.8;
  }
</style>