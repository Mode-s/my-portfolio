---
const name = "Shota";
const skills = ["JavaScript", "TypeScript", "React", "Astro"];
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<title>{`${name}のポートフォリオ`}</title>
	</head>
	<body>
		<h1>{`こんにちは、${name}です`}</h1>
		<p>Astroでポートフォリオを作っています。</p>
		<h2>学んでいる技術</h2>
		<ul>
			{skills.map((skill) => <li>{skill}</li>)}
		</ul>
	</body>
</html>
